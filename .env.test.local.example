# ─────────────────────────────────────────────────────────────────────────
# Tests E2E Playwright — copier en `.env.test.local` et remplir.
# ⚠️ Utiliser un environnement de TEST dédié, jamais des comptes de production.
# ─────────────────────────────────────────────────────────────────────────

# URL de l'app à tester. En local, laissée vide → Playwright lance `npm run dev`.
# En CI, doit pointer vers une app déployée (preview Vercel / staging).
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Compte syndic de test (gestionnaire)
TEST_SYNDIC_EMAIL=
TEST_SYNDIC_PASSWORD=

# Compte copropriétaire (portail)
TEST_PORTAIL_EMAIL=
TEST_PORTAIL_PASSWORD=

# Compte locataire (portail allégé)
TEST_TENANT_EMAIL=
TEST_TENANT_PASSWORD=
