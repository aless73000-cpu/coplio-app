# ═══════════════════════════════════════
# COPLIO — Variables d'environnement
# ═══════════════════════════════════════
# Copier ce fichier en .env.local et remplir les valeurs

# ─── SUPABASE ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=VOTRE_JWT_SECRET
# Connexion directe (optionnel — pour migrations Prisma/drizzle)
# DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ─── STRIPE ─────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prix Stripe (créer dans le dashboard Stripe)
STRIPE_PRICE_STARTER=price_...      # 79€/mois
STRIPE_PRICE_PRO=price_...          # 149€/mois (populaire)
STRIPE_PRICE_EXPERT=price_...       # 299€/mois
STRIPE_PRICE_ADDON_PORTAIL=price_... # 0.30€/lot/mois

# ─── RESEND (Emails) ────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@coplio.fr
# Secret pour valider les webhooks Resend (Resend > Webhooks > Signing secret)
RESEND_WEBHOOK_SECRET=whsec_...

# ─── TWILIO (SMS) ───────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+33...

# ─── WEB PUSH (Notifications) ───────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:contact@coplio.fr

# ─── GLITCHTIP (Monitoring erreurs) ─────
# Copier l'URL DSN depuis GlitchTip > Settings > SDK Setup
GLITCHTIP_DSN=https://VOTRE_CLE@app.glitchtip.com/1

# ─── SIGNATURES ÉLECTRONIQUES (YouSign) ─
YOUSIGN_API_KEY=...
YOUSIGN_ENV=sandbox          # sandbox | production
YOUSIGN_WEBHOOK_SECRET=...

# ─── IA (Gemini) ────────────────────────
# Optionnel — fonctionnalité IA (résumés, suggestions)
GEMINI_API_KEY=...

# ─── ANALYTICS (Plausible) ──────────────
# Optionnel — domaine configuré dans Plausible Dashboard
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=coplio.fr

# ─── SÉCURITÉ CRONS ─────────────────────
# Générer avec : openssl rand -hex 32
# À configurer aussi dans Vercel > Settings > Environment Variables
CRON_SECRET=...

# ─── ADMIN ──────────────────────────────
# Emails séparés par virgule pour les alertes critiques
ADMIN_ALERT_EMAIL=team@coplio.fr
ADMIN_EMAILS=admin@coplio.fr

# ─── DEV UNIQUEMENT ─────────────────────
# Forcer tous les emails vers cette adresse en développement
# EMAIL_DEV_OVERRIDE=ton@email.com

# ─── APPLICATION ────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Coplio
