# ═══════════════════════════════════════════════════════════════
# COPLIO — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez chaque valeur.
# Ne commitez jamais .env.local dans git.
# ═══════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────
# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=https://coplio.fr

# ─── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ Clé service_role — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# URL directe PostgreSQL (pour les migrations)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Stripe ───────────────────────────────────────────────────
# Dashboard Stripe → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_live_...
# Dashboard Stripe → Développeurs → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard Stripe → Produits → IDs des prix (mode live)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EXPERT=price_...
STRIPE_PRICE_ADDON_PORTAIL=price_...

# ─── Resend (emails transactionnels) ─────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# Adresse expéditeur vérifiée dans Resend (ex: noreply@coplio.fr)
RESEND_FROM_EMAIL=noreply@coplio.fr
# Dashboard Resend → Webhooks → Signing secret
RESEND_WEBHOOK_SECRET=whsec_...
# Optionnel : redirige tous les emails vers cette adresse en dev/staging
# EMAIL_DEV_OVERRIDE=dev@coplio.fr

# ─── Google Gemini (IA) ───────────────────────────────────────
# console.cloud.google.com → Credentials → API Key
GEMINI_API_KEY=AIzaSy...

# ─── Upstash Redis (rate limiting) ───────────────────────────
# upstash.com → votre base → REST API
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Push Notifications (Web Push / VAPID) ───────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Format : mailto:email@coplio.fr  ou  https://coplio.fr
VAPID_SUBJECT=mailto:contact@coplio.fr

# ─── Yousign (signatures électroniques) ──────────────────────
# yousign.com → Settings → API
YOUSIGN_API_KEY=...
# Environnement : "sandbox" en dev, "production" en prod
YOUSIGN_ENV=sandbox
# Secret de vérification des webhooks Yousign
YOUSIGN_WEBHOOK_SECRET=...

# ─── Twilio (SMS relances) ────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Numéro Twilio au format E.164 (ex: +33xxxxxxxxx)
TWILIO_FROM_NUMBER=+33xxxxxxxxx

# ─── Admin ────────────────────────────────────────────────────
# Liste d'emails autorisés à accéder au back-office /admin (séparés par des virgules)
ADMIN_EMAILS=admin@coplio.fr,cto@coplio.fr
# Email de réception des alertes critiques système
ADMIN_ALERT_EMAIL=alertes@coplio.fr

# ─── Cron Jobs (Vercel) ───────────────────────────────────────
# Secret partagé entre Vercel Cron et les routes /api/cron/*
# Générer avec : openssl rand -base64 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Analytics (optionnel) ────────────────────────────────────
# Laisser vide pour désactiver Plausible Analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=coplio.fr

# ─── Sentry (monitoring erreurs) ─────────────────────────────
# sentry.io → Settings → Projects → Client Keys (DSN)
# SENTRY_ORG et SENTRY_PROJECT : utilisés au build pour uploader les source maps
SENTRY_ORG=coplio
SENTRY_PROJECT=coplio-app
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx
# Auth token pour l'upload des source maps (CI/CD uniquement — ne pas mettre en .env.local)
# SENTRY_AUTH_TOKEN=sntrys_...
